{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "pre-commit": {
    "enabled": true
  },
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(deps)",
    "group:allNonMajor",
    "group:monorepos",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel('security')",
    ":maintainLockFilesWeekly",
    "schedule:nonOfficeHours"
  ],
  "timezone": "Europe/Paris",
  "labels": ["dependencies"],
  "assignees": ["foXaCe"],
  "reviewers": ["foXaCe"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "rangeStrategy": "bump",
  "rebaseWhen": "auto",
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "📦 Renovate Dependency Dashboard",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"],
    "prCreation": "immediate"
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major", "needs-review"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["npm"],
      "labels": ["dependencies", "javascript"]
    },
    {
      "matchManagers": ["pre-commit"],
      "labels": ["dependencies", "pre-commit"]
    },
    {
      "matchPackageNames": ["apexcharts"],
      "labels": ["dependencies", "apexcharts", "needs-review"]
    },
    {
      "matchPackageNames": ["lit"],
      "labels": ["dependencies", "lit"]
    },
    {
      "matchPackageNames": ["/^@types//"],
      "groupName": "types"
    },
    {
      "matchPackageNames": ["eslint", "prettier", "/eslint/", "/prettier/"],
      "groupName": "lint & format tools"
    },
    {
      "matchPackageNames": ["rollup", "/^@rollup//", "/^@babel//", "/^rollup-plugin/"],
      "groupName": "build tools"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "platformAutomerge": true
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/dist/**"]
}
