{
  "name": "apexcharts-card",
  "version": "2.6.1",
  "description": "A Home Assistant Lovelace card using ApexCharts to render graphs",
  "type": "module",
  "main": "dist/apexcharts-card.js",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "build": "npm run build:types-check && npm run typecheck && npm run rollup",
    "build:types-check": "ts-interface-builder src/types-config.ts",
    "typecheck": "tsc --noEmit",
    "rollup": "rollup -c",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "watch": "npm run build:types-check && rollup -c --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foXaCe/apexcharts-card.git"
  },
  "keywords": [
    "lovelace",
    "apexcharts",
    "graphs",
    "charts",
    "home-assistant"
  ],
  "author": "Jérôme Wiedemann",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/foXaCe/apexcharts-card/issues"
  },
  "homepage": "https://github.com/foXaCe/apexcharts-card#readme",
  "dependencies": {
    "@ctrl/tinycolor": "^4.2.0",
    "@material/mwc-ripple": "^0.27.0",
    "apexcharts": "^5.16.0",
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.3",
    "localforage": "^1.10.0",
    "lz-string": "^1.5.0",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "moment-range": "^4.0.2",
    "moment-timezone": "^0.6.2",
    "parse-duration": "^2.1.6",
    "spark-md5": "^3.0.2",
    "ts-interface-checker": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lz-string": "^1.5.0",
    "@types/moment-duration-format": "^2.2.7",
    "@types/spark-md5": "^3.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "home-assistant-js-websocket": "^9.6.0",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "rollup-plugin-serve": "^3.0.0",
    "ts-interface-builder": "^0.3.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
